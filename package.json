{
  "name": "pintarai",
  "version": "0.1.0",
  "description": "PintarAI - Asisten Belajar Offline untuk Siswa Indonesia",
  "private": true,
  "main": "electron-dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite --port 5173\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "export:model:android": "python scripts/export-nemotron-onnx.py",
    "manifest:model:android": "node scripts/generate-android-model-manifest.mjs",
    "validate:model:android": "python scripts/validate-nemotron-export.py",
    "prepare-bundle": "node scripts/prepare-bundle.js",
    "dist": "npm run build && npm run build:electron && electron-builder",
    "preview": "vite preview",
    "prepare-android": "node scripts/prepare-android.cjs",
    "build:android": "npm run build && npx cap sync android",
    "open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@fontsource/baloo-2": "^5.1.0",
    "@fontsource/comic-neue": "^5.1.0",
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@wllama/wllama": "^2.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-static-copy": "^4.0.1",
    "wait-on": "^7.2.0"
  }
}
